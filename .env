# EFS
EFS_FILE_DIRE=/tmp/efs

# DATASOURCE (use 'postgres' user which is the default PostgreSQL superuser)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mydb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=admin

# PostgreSQL Container Setup
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=mydb
POSTGRES_PORT=5432

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

TOPIC_TEST=test-topic
TOPIC_TRUCK=truck-topic
TOPIC_SCRAP=scrapping-topic

# Email
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=ce545af2135fd6
MAIL_PASSWORD=35f35312703886

# Socket
SOCKET_SESSION_ID=0hw0dz34
SOCKET_TRANSACTION_ID=40ef-dd1d-bd9f-1d7f

# PgAdmin (optional, for Docker Compose)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Zookeeper
ZOOKEEPER_PORT=2181

# Kafka
KAFKA_PORT=9092

# Spring Boot
SPRING_BOOT_PORT=9098

# ============================================
# Monitoring Configuration
# ============================================

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Node Exporter
NODE_EXPORTER_PORT=9100

